#!/usr/bin/env bash
# Host wrapper for bench.mjs — runs the benchmark inside a Docker container
# that has network access to Ollama. Useful when Ollama runs on a private
# user-defined network with no host port publish, so the host can't reach
# it directly but a sibling container can.
#
# Configure via environment variables:
#   OLLAMA_BENCH_CONTAINER          sibling container name (Node 20+, network
#                                   access to Ollama). Default: tries
#                                   "openclaw" then "engine-openclaw-1".
#   OLLAMA_BENCH_OLLAMA_CONTAINER   name of the Ollama container; the wrapper
#                                   runs `docker inspect` on it to capture
#                                   OLLAMA_* server env. Default: "ollama".
#   OLLAMA_BENCH_REMOTE_DIR         writable path inside the sibling for
#                                   scripts + baseline. Default: /tmp.
#   OLLAMA_BENCH_MACHINE_ID         stable machine fingerprint seed; auto-
#                                   populated from /etc/machine-id (or
#                                   /var/lib/dbus/machine-id) when readable.
#   OLLAMA_BENCH_TIMEOUT_MS         per-call request timeout override
#                                   (forwarded to the harness).
#
# The wrapper also runs `nvidia-smi` and `docker inspect` on the host and
# forwards the results into the sibling as OLLAMA_BENCH_GPU_CSV /
# OLLAMA_BENCH_GPU_EXT_CSV / OLLAMA_BENCH_SERVER_ENV_JSON /
# OLLAMA_BENCH_CPU_GOVERNOR / OLLAMA_BENCH_SWAP. The harness prefers these
# over its own probes, so GPU + host + server-env data lands in the baseline
# even when the sibling can't see them directly.
#
# Usage: same as `node bench.mjs`. Passes all arguments through.
#   ./bench                          # smart perf run for current --model
#   ./bench rank --model qwen3:30b   # add or refresh a model in the league
#   ./bench league                   # ranked table across all benched models
#   ./bench doctor                   # preflight system audit
#   ./bench --help                   # full CLI

set -euo pipefail

HERE="$(cd "$(dirname "$0")" && pwd)"
BASELINE_HOST="$HERE/baseline.json"

CONTAINER="${OLLAMA_BENCH_CONTAINER:-}"
if [[ -z "$CONTAINER" ]]; then
  for candidate in openclaw engine-openclaw-1; do
    if docker ps --filter "name=^${candidate}$" --format '{{.Names}}' | grep -qx "$candidate"; then
      CONTAINER="$candidate"; break
    fi
  done
fi
if [[ -z "$CONTAINER" ]]; then
  echo "no sibling container found; set OLLAMA_BENCH_CONTAINER=<name>" >&2
  exit 1
fi
if ! docker ps --filter "name=^${CONTAINER}$" --format '{{.Names}}' | grep -qx "$CONTAINER"; then
  echo "container '$CONTAINER' is not running" >&2
  exit 1
fi

REMOTE_DIR="${OLLAMA_BENCH_REMOTE_DIR:-/tmp}"
REMOTE_BASELINE="$REMOTE_DIR/ollama-bench-baseline.json"

# The unified CLI spawns the probe scripts as siblings, and both probes
# import the shared tool catalogue, so all four files must live next to
# each other in the container. Fail fast if any are missing on the host.
SCRIPTS=(bench.mjs bench-toolcall.mjs bench-multiturn.mjs bench-tools.mjs bench-doctor.mjs bench-baseline.mjs)
MISSING=()
for script in "${SCRIPTS[@]}"; do
  [[ -f "$HERE/$script" ]] || MISSING+=("$script")
done
if (( ${#MISSING[@]} > 0 )); then
  echo "missing harness files next to wrapper: ${MISSING[*]}" >&2
  exit 2
fi
for script in "${SCRIPTS[@]}"; do
  docker exec -i "$CONTAINER" sh -c "cat > $REMOTE_DIR/$script" < "$HERE/$script"
done

# Stable machine fingerprint — read the host's machine-id and pass it in.
# Without this, machineId hashes the container's hostname (= container id),
# which changes on every recreate and invalidates the baseline.
HOST_MACHINE_ID=""
for f in /etc/machine-id /var/lib/dbus/machine-id; do
  if [[ -r "$f" ]]; then HOST_MACHINE_ID=$(cat "$f" 2>/dev/null || true); break; fi
done

# Env snapshot — the sibling container typically has neither nvidia-smi on
# PATH nor access to the Docker socket, so bench.mjs's in-container probes
# for GPU state and OLLAMA_* server env come back empty. Run them on the
# host and forward via env vars; bench.mjs prefers injected data over its
# own local commands.
HOST_NVIDIA_SMI=""
HOST_NVIDIA_SMI_EXT=""
if command -v nvidia-smi >/dev/null 2>&1; then
  HOST_NVIDIA_SMI=$(nvidia-smi --query-gpu=name,driver_version,memory.total,memory.used,utilization.gpu,temperature.gpu,power.draw,clocks.current.sm --format=csv,noheader,nounits 2>/dev/null) || HOST_NVIDIA_SMI=""
  # Extended field set consumed by bench-doctor.mjs (GPU_FIELDS there must match).
  HOST_NVIDIA_SMI_EXT=$(nvidia-smi --query-gpu=name,driver_version,persistence_mode,power.default_limit,power.max_limit,clocks_throttle_reasons.active --format=csv,noheader,nounits 2>/dev/null) || HOST_NVIDIA_SMI_EXT=""
fi

# Host-only probes for bench-doctor. The sibling container can't read the
# host's sysfs or /proc, so snapshot on the host and forward via env.
HOST_CPU_GOVERNOR=""
if ls /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor >/dev/null 2>&1; then
  HOST_CPU_GOVERNOR=$(cat /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor 2>/dev/null || true)
fi
HOST_SWAP=""
if command -v free >/dev/null 2>&1; then
  HOST_SWAP=$(free -m | awk '/^Swap:/ {print $2, $3}' 2>/dev/null || true)
fi

OLLAMA_CONTAINER="${OLLAMA_BENCH_OLLAMA_CONTAINER:-ollama}"
HOST_OLLAMA_ENV=""
if docker ps --filter "name=^${OLLAMA_CONTAINER}$" --format '{{.Names}}' 2>/dev/null | grep -qx "$OLLAMA_CONTAINER"; then
  HOST_OLLAMA_ENV=$(docker inspect "$OLLAMA_CONTAINER" --format '{{json .Config.Env}}' 2>/dev/null) || HOST_OLLAMA_ENV=""
fi

# Seed baseline from host if we have one. Capture content hash so we can
# detect mutation after the run without being fooled by mtime bumps from
# the copy-in itself.
if [[ -f "$BASELINE_HOST" ]]; then
  docker exec -i "$CONTAINER" sh -c "cat > $REMOTE_BASELINE" < "$BASELINE_HOST"
  PRE_HASH=$(md5sum "$BASELINE_HOST" | cut -d' ' -f1)
else
  docker exec "$CONTAINER" rm -f "$REMOTE_BASELINE"
  PRE_HASH=""
fi

# Inject --out so the script points at the in-container baseline path.
# (User-supplied --out would be a host path and wouldn't exist inside the container.)
EXEC_ENV=()
if [[ -n "$HOST_MACHINE_ID" ]]; then
  EXEC_ENV+=(-e "OLLAMA_BENCH_MACHINE_ID=$HOST_MACHINE_ID")
fi
# Export + `-e KEY` (no value) is the robust form for multi-line / JSON
# payloads: docker forwards the variable from the wrapper's environment
# rather than trying to parse it as a KEY=VAL argument.
if [[ -n "$HOST_NVIDIA_SMI" ]]; then
  export OLLAMA_BENCH_GPU_CSV="$HOST_NVIDIA_SMI"
  EXEC_ENV+=(-e OLLAMA_BENCH_GPU_CSV)
fi
if [[ -n "$HOST_NVIDIA_SMI_EXT" ]]; then
  export OLLAMA_BENCH_GPU_EXT_CSV="$HOST_NVIDIA_SMI_EXT"
  EXEC_ENV+=(-e OLLAMA_BENCH_GPU_EXT_CSV)
fi
if [[ -n "$HOST_OLLAMA_ENV" ]]; then
  export OLLAMA_BENCH_SERVER_ENV_JSON="$HOST_OLLAMA_ENV"
  EXEC_ENV+=(-e OLLAMA_BENCH_SERVER_ENV_JSON)
fi
if [[ -n "$HOST_CPU_GOVERNOR" ]]; then
  export OLLAMA_BENCH_CPU_GOVERNOR="$HOST_CPU_GOVERNOR"
  EXEC_ENV+=(-e OLLAMA_BENCH_CPU_GOVERNOR)
fi
if [[ -n "$HOST_SWAP" ]]; then
  export OLLAMA_BENCH_SWAP="$HOST_SWAP"
  EXEC_ENV+=(-e OLLAMA_BENCH_SWAP)
fi
set +e
docker exec "${EXEC_ENV[@]}" "$CONTAINER" node "$REMOTE_DIR/bench.mjs" "$@" --out "$REMOTE_BASELINE"
EXIT=$?
set -e

# Sync baseline state back to host only if the run actually changed it
# (content hash differs, or the file was deleted in-container).
if [[ $EXIT -eq 0 ]]; then
  if docker exec "$CONTAINER" test -f "$REMOTE_BASELINE"; then
    POST_HASH=$(docker exec "$CONTAINER" md5sum "$REMOTE_BASELINE" | cut -d' ' -f1)
    if [[ "$POST_HASH" != "$PRE_HASH" ]]; then
      docker exec "$CONTAINER" cat "$REMOTE_BASELINE" > "$BASELINE_HOST"
      echo "host baseline: $BASELINE_HOST"
    fi
  elif [[ -n "$PRE_HASH" ]]; then
    rm -f "$BASELINE_HOST"
    echo "host baseline cleared: $BASELINE_HOST"
  fi
fi

exit $EXIT
